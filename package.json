{
  "name": "pointer",
  "private": true,
  "version": "0.4.5",
  "description": "Desktop PostgreSQL explorer built with Electron and React",
  "author": "Roberto",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "pnpm run typecheck && vite build",
    "dist:mac": "pnpm run build && electron-builder --mac dmg zip",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.1",
